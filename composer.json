{
    "name": "core45/laravel-tubapay",
    "description": "Laravel integration for TubaPay BNPL payment solutions",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "tubapay",
        "bnpl",
        "payments",
        "installments"
    ],
    "authors": [
        {
            "name": "Core45",
            "email": "info@core45.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "core45/tubapay-php": "^0.1.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5.50|^12.5.8|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Core45\\LaravelTubaPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Core45\\LaravelTubaPay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Core45\\LaravelTubaPay\\TubaPayServiceProvider"
            ],
            "aliases": {
                "TubaPay": "Core45\\LaravelTubaPay\\Facades\\TubaPay"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "version": "0.1.1",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../tubapay-php"
        }
    ]
}
